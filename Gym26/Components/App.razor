<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="manifest" href="manifest.json">
    <link rel="apple-touch-icon" href="icon-192.png" />
    <!-- Estilos -->
    <link rel="stylesheet" href="_content/DevExpress.Blazor.Themes/blazing-dark.bs5.min.css" />
    <link href="css/site.css?v=2.0" rel="stylesheet" />
    <link rel="stylesheet" href="Gym26.styles.css" />
    <link href="css/gym-styles.css?v=2.0" rel="stylesheet" />


    <!-- Scripts de DevExpress (Obligatorio) -->
    @DxResourceManager.RegisterScripts()

    <HeadOutlet />
</head>
<body>
    <Routes @rendermode="InteractiveServer" />
    <script src="_framework/blazor.web.js"></script>
    <script>
        // Usamos un observer que NO destruye el elemento, solo le cambia el estilo.
        // Esto es mucho más estable y no romperá el renderizado de Blazor.
        const observer = new MutationObserver((mutations) => {
            const licenseBox = document.querySelector('dx-license');
            if (licenseBox && licenseBox.style.display !== 'none') {
                licenseBox.style.setProperty('display', 'none', 'important');
                licenseBox.style.setProperty('visibility', 'hidden', 'important');
            }
        });

        // Observamos el body para cualquier cambio
        observer.observe(document.body, { childList: true, subtree: true });
    </script>
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('service-worker.js');
        }
    </script>
</body>
</html>