@page "/gestion-ejercicios"
@using Gym26.Models
@using Gym26.Services
@using DevExpress.Blazor
@inject GymService GymService
@inject UserSession UserSession

<h3 class="mb-4">Gestión de Ejercicios</h3>

@if (listaEjercicios == null)
{
    <p><em>Cargando ejercicios...</em></p>
}
else
{
    <DxGrid Data="@listaEjercicios"
            EditMode="GridEditMode.EditRow"
            EditModelSaving="OnEditModelSaving"
            DataItemDeleting="OnDataItemDeleting">
        <!-- Añade esta línea -->
        <Columns>
            <DxGridCommandColumn Width="100px" ShowDeleteButton="true" /> <!-- Asegúrate que el botón de borrar esté habilitado -->
            <DxGridDataColumn FieldName="Nombre" />
            <DxGridCommandColumn Width="100px" />
            <DxGridDataColumn FieldName="Nombre" />
            <DxGridDataColumn FieldName="GrupoMuscular" />
            <DxGridDataColumn FieldName="UrlGif" Caption="Link del GIF">
                <CellDisplayTemplate>
                    <a href="@context.Value" target="_blank">Ver GIF</a>
                </CellDisplayTemplate>
            </DxGridDataColumn>
        </Columns>
    </DxGrid>
}

@code {
    IEnumerable<Ejercicio>? listaEjercicios;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    async Task CargarDatos()
    {
        // Ahora (solucionado)
        listaEjercicios = (await GymService.GetEjerciciosAsync(UserSession.UsuarioId)).ToList();
    }

    async Task OnEditModelSaving(GridEditModelSavingEventArgs e)
    {
        var ejercicioEditado = (Ejercicio)e.EditModel;

        await GymService.ActualizarEjercicioAsync(ejercicioEditado);

        await CargarDatos();
    }

    async Task OnDataItemDeleting(GridDataItemDeletingEventArgs e)
    {
        // 1. Obtenemos el ejercicio desde el evento
        var ejercicioAEliminar = (Ejercicio)e.DataItem;

        // 2. Llamamos al servicio (asegúrate de que este método exista en GymService)
        // Usamos el ID del ejercicio
        await GymService.EliminarEjercicioAsync(ejercicioAEliminar.Id);

        // 3. Recargamos la lista para reflejar el cambio
        await CargarDatos();
    }
}