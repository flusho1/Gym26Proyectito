@page "/planes"
@using Gym26.Models
@using Gym26.Services
@inject GymService GymService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject Gym26.Services.UserSession _session



@if (listaPlantillas == null)
{
    <div class="spinner-border text-info"></div>
}
else
{
    @* <DxGrid Data="@listaPlantillas" KeyFieldName="Id">
        <Columns>
            <DxGridDataColumn FieldName="Nombre" Caption="Nombre" />
            <DxGridDataColumn Caption="Tipo" Width="100px">
                <CellDisplayTemplate>
                    @{
                        var p = (Plantilla)context.DataItem;
                        <span class="badge @(p.UsuarioId == null ? "bg-secondary" : "bg-primary")">
                            @(p.UsuarioId == null ? "Global" : "Personal")
                        </span>
                    }
                </CellDisplayTemplate>
            </DxGridDataColumn>
        </Columns>
    </DxGrid> *@
}
<div class="container-fluid pt-4">
    <h3 class="text-neon mb-4">Mapa de Entrenamiento</h3>

    <div class="row">
        @if (planes == null)
        {
            <div class="spinner-border text-info"></div>
        }
        else
        {
            @foreach (var plan in planes)
            {
                <div class="card bg-dark text-white neon-border mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="card-title">@plan.NombreDia</h5>
                                <p class="card-text">@plan.Descripcion</p>
                            </div>
                            <!-- Botón de eliminar -->
                            <button class="btn btn-outline-danger" @onclick="() => EliminarPlan(plan.Id)">
                                <i class="oi oi-trash"></i>
                            </button>
                        </div>

                        <button class="btn btn-outline-neon w-100 mt-2"
                                @onclick="() => SeleccionarPlan(plan.Id)">
                            Cargar Rutina
                        </button>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    private List<Plantilla> listaPlantillas;
    List<PlanRutina> planes = new();

    protected override async Task OnInitializedAsync()
    {
        await CargarPlanes(); // Llamamos al método centralizado
    }

    private async Task CargarPlanes()
    {
        listaPlantillas = await GymService.GetPlantillasAsync();
        planes = await GymService.GetPlanesAsync();
    }

    private async Task SeleccionarPlan(int id)
    {
        Navigation.NavigateTo($"/rutinas/{id}");
    }

    private async Task EliminarPlan(int id)
    {
        bool confirmado = await JS.InvokeAsync<bool>("confirm", "¿Seguro que quieres borrar este plan?");

        if (confirmado)
        {
            // Asegúrate de que este método en GymService use el filtro usuarioid
            await GymService.EliminarPlanAsync(id, _session.UsuarioId);
            await CargarPlanes(); // Recarga los datos y refresca la UI
        }
    }
}